<div class="pf-view search-view">
  <input
    class="search-box"
    type="search"
    value="{{query}}"
    placeholder="Search documents"
    aria-label="Search documents"
    data-search-input
    data-action="search-input"
    autocomplete="off"
  >

  <nav class="sub-rail rail search-type-rail" aria-label="Search result type filters">
    {{#each typeFilters}}
      <button
        class="{{#if active}}active{{/if}}"
        type="button"
        data-action="search-type-filter"
        data-type-filter="{{value}}"
        aria-pressed="{{#if active}}true{{else}}false{{/if}}"
      >{{label}}</button>
    {{/each}}
  </nav>

  <div class="section pf-view-section search-results" data-search-results>
    <div class="section-heading pf-view-section-heading">
      <h2>Live Results</h2>
      {{#if loading}}<span class="mini" role="status">Searching</span>{{/if}}
    </div>

    {{#if errors.length}}
      <div class="empty-state search-error-state" role="status">
        <h2>Partial Results</h2>
        <p>Some searchable content could not be queried.</p>
      </div>
    {{/if}}

    {{#if results.length}}
      {{#each results}}
        <a
          class="row search-result-row {{#if focused}}focused{{/if}}"
          href="#"
          role="link"
          tabindex="0"
          data-action="open-search-result"
          data-result-id="{{uuid}}"
          aria-label="{{name}}, {{type}}"
        >
          <span class="item-icon" aria-hidden="true">
            {{#if icon}}<img src="{{icon}}" alt="">{{else}}{{iconText}}{{/if}}
          </span>
          <span class="row-title">
            <strong>{{name}}</strong>
            <span>{{subtitle}}</span>
            {{#if snippet}}<span class="search-snippet">{{snippet}}</span>{{/if}}
          </span>
          <span class="row-action">{{actionLabel}}</span>
        </a>
      {{/each}}
    {{else}}
      {{#if hasUsableQuery}}
        {{#unless loading}}
          {{> "modules/pocket-foundry/templates/partials/empty-state.hbs" title="No Results" body="No documents match this search."}}
        {{/unless}}
      {{else}}
        {{> "modules/pocket-foundry/templates/partials/empty-state.hbs" title="Search Content" body="Enter at least one character to search Characters, Items, and Journals."}}
      {{/if}}
    {{/if}}
  </div>
</div>
