{{#if unavailable}}
  <section class="content pf-view journal-entry-view" data-region="journal-entry-unavailable">
    <div class="section pf-view-section">
      {{> "modules/pocket-foundry/templates/partials/empty-state.hbs" title=title body=body}}
    </div>
  </section>
{{else}}
  <section class="content pf-view journal-entry-view" data-region="journal-entry-pages" data-entry-uuid="{{uuid}}">
    <section class="section content-group pf-view-section journal-page-list">
      <div class="section-heading content-group-heading pf-view-section-heading journal-page-list-heading">
        <h2>Journal Pages</h2>
        {{#if canCreatePage}}
          <button class="journal-create-page-button" type="button" data-action="journal-create-page" data-entry-uuid="{{uuid}}" aria-label="Create journal page" title="Create page">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            <span>Create</span>
          </button>
        {{/if}}
      </div>
      {{#if hasPages}}
        <div class="content-table content-list pf-view-list journal-list">
          <div class="content-list-head journal-list-head" aria-hidden="true">
            <span>Name</span>
            <span>Type</span>
            <span></span>
          </div>
          {{#each visiblePages}}
            <div class="row content-list-row journal-page-row">
              <button class="journal-page-row-main" type="button" data-action="journal-open-page" data-entry-uuid="{{../uuid}}" data-page-uuid="{{uuid}}">
                <span class="item-icon" aria-hidden="true">{{iconText}}</span>
                <span class="row-title content-row-title">
                  <strong>{{name}}</strong>
                  <span>{{#if category}}{{category}}{{else}}Journal Page{{/if}}</span>
                </span>
                <span class="content-list-value journal-list-value">{{typeLabel}}</span>
              </button>
              {{#if canDelete}}
                <button class="row-action content-list-action journal-page-delete-button" type="button" data-action="journal-delete-page" data-entry-uuid="{{../uuid}}" data-page-uuid="{{uuid}}" aria-label="Delete {{name}}" title="Delete page">
                  <i class="fa-solid fa-trash" aria-hidden="true"></i>
                </button>
              {{else}}
                <span class="row-action content-list-action" aria-hidden="true"></span>
              {{/if}}
            </div>
          {{/each}}
        </div>
      {{else}}
        {{> "modules/pocket-foundry/templates/partials/empty-state.hbs" title="No Visible Pages" body="Pages you can view will appear here."}}
      {{/if}}
    </section>
  </section>
{{/if}}
