{
  "name": "pocket-foundry",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "node --experimental-transform-types scripts/build.ts --clean",
    "build": "node --experimental-transform-types scripts/build.ts",
    "check:unused": "node node_modules/typescript/bin/tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "test": "npm run check:unused && vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && node --experimental-transform-types tests/e2e/browser-history.test.ts && node --experimental-transform-types tests/e2e/favorite-context.test.ts",
    "test:browser": "npm run test:e2e",
    "deploy": "npm run devdeploy",
    "devdeploy": "npm run test && npm run build && node --experimental-transform-types scripts/devdeploy.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.8"
  }
}
